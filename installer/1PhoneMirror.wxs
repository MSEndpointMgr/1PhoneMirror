<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 5 source for 1PhoneMirror.
  Build via package.ps1 (which installs the WiX dotnet tool, stages files,
  and invokes `wix build`). See package.ps1 for the exact command line.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="1PhoneMirror"
           Manufacturer="Simon Skotheimsvik"
           Version="$(Version)"
           UpgradeCode="6F4E6B5C-2E4A-4B1F-9D2E-7B5C8F3A1E10"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perMachine">

    <SummaryInformation Description="1PhoneMirror — wireless screen mirroring for iOS and Android"
                        Manufacturer="Simon Skotheimsvik" />

    <!-- Block downgrades, allow seamless upgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of 1PhoneMirror is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- License (RTF, optional, used by the WixUI_Minimal dialog). -->
    <WixVariable Id="WixUILicenseRtf" Value="installer\License.rtf" />
    <ui:WixUI Id="WixUI_Minimal" />

    <!-- Install directories -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="1PhoneMirror" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="1PhoneMirror" />
    </StandardDirectory>

    <!-- Files. The whole staging directory is harvested via wix.exe at build time
         (see package.ps1 which runs `heat` / `harvest`), but we also list the
         primary EXE explicitly so we can reference it for shortcuts and firewall. -->
    <ComponentGroup Id="MainExecutable" Directory="INSTALLFOLDER">
      <Component Id="cmpMainExe" Guid="*">
        <File Id="exe.OnePhoneMirror"
              Source="$(StagingDir)\1PhoneMirror.exe"
              KeyPath="yes">

          <!-- Firewall: allow the EXE itself, both TCP and UDP, all profiles.
               Nesting under <File> binds the rule to this program path so
               Windows does not prompt the user on first listen. -->
          <fire:FirewallException Id="fwTcp"
                                  Name="1PhoneMirror (TCP)"
                                  Protocol="tcp"
                                  Scope="any"
                                  Profile="all"
                                  IgnoreFailure="yes" />
          <fire:FirewallException Id="fwUdp"
                                  Name="1PhoneMirror (UDP)"
                                  Protocol="udp"
                                  Scope="any"
                                  Profile="all"
                                  IgnoreFailure="yes" />
        </File>
      </Component>
    </ComponentGroup>

    <!-- Auto-harvested supporting files (DLLs, PNGs, license).  package.ps1 runs
         `wix.exe extension add` + a HarvestDirectory call to fill this group. -->
    <ComponentGroup Id="HarvestedFiles" Directory="INSTALLFOLDER">
      <Files Include="$(StagingDir)\**">
        <!-- Don't double-add the main EXE handled above. -->
        <Exclude Files="$(StagingDir)\1PhoneMirror.exe" />
      </Files>
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <ComponentGroup Id="Shortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="cmpStartMenu" Guid="*">
        <Shortcut Id="StartMenuShortcut"
                  Name="1PhoneMirror"
                  Description="Wireless screen mirroring for iOS and Android"
                  Target="[#exe.OnePhoneMirror]"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppShortcutFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\1PhoneMirror"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="1PhoneMirror" Level="1">
      <ComponentGroupRef Id="MainExecutable" />
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

  </Package>
</Wix>
