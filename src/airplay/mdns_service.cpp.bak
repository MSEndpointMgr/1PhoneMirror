#include <openmirror/airplay/mdns_service.h>
#include <iostream>
#include <sstream>
#include <iomanip>
#include <vector>
#include <utility>

// --- DNS-SD backend selection ---
// Priority: 1) Apple Bonjour SDK  2) Windows native DNS-SD  3) none
#if __has_include(<dns_sd.h>)
    #define MDNS_BACKEND_BONJOUR 1
    #ifdef _WIN32
        #include <dns_sd.h>
        #pragma comment(lib, "dnssd.lib")
    #else
        #include <dns_sd.h>
    #endif
#elif defined(_WIN32)
    #define MDNS_BACKEND_WINDNS 1
    #include <winsock2.h>
    #include <windns.h>
    #pragma comment(lib, "dnsapi.lib")
#endif

namespace openmirror::airplay {

// ============================================================
// Impl definition (backend-specific members)
// ============================================================
struct MdnsService::Impl {
#if defined(MDNS_BACKEND_BONJOUR)
    DNSServiceRef airplay_ref = nullptr;
    DNSServiceRef raop_ref = nullptr;
#elif defined(MDNS_BACKEND_WINDNS)
    PDNS_SERVICE_INSTANCE airplay_instance = nullptr;
    PDNS_SERVICE_INSTANCE raop_instance = nullptr;
    DNS_SERVICE_CANCEL airplay_cancel{};
    DNS_SERVICE_CANCEL raop_cancel{};
    bool airplay_registered = false;
    bool raop_registered = false;
#endif
};

MdnsService::MdnsService() : impl_(new Impl) {}

MdnsService::~MdnsService() {
    unregister();
    delete impl_;
}

// --- Shared helpers ---

static std::string mac_to_string(const uint8_t addr[6]) {
    std::ostringstream oss;
    for (int i = 0; i < 6; i++) {
        if (i > 0) oss << ':';
        oss << std::hex << std::setfill('0') << std::setw(2)
            << static_cast<int>(addr[i]);
    }
    return oss.str();
}

static std::string mac_to_id(const uint8_t addr[6]) {
    std::ostringstream oss;
    for (int i = 0; i < 6; i++) {
        oss << std::hex << std::setfill('0') << std::setw(2)
            << static_cast<int>(addr[i]);
    }
    return oss.str();
}

// ============================================================
// Backend 1: Apple Bonjour SDK
// ============================================================
#if defined(MDNS_BACKEND_BONJOUR)

static std::vector<uint8_t> build_txt_record(const std::map<std::string, std::string>& entries) {
    std::vector<uint8_t> txt;
    for (const auto& [key, val] : entries) {
        std::string entry = key + "=" + val;
        if (entry.size() > 255) continue;
        txt.push_back(static_cast<uint8_t>(entry.size()));
        txt.insert(txt.end(), entry.begin(), entry.end());
    }
    return txt;
}

static void DNSSD_API register_callback(
    DNSServiceRef, DNSServiceFlags, DNSServiceErrorType error,
    const char* name, const char* regtype, const char* domain, void*) {
    if (error == kDNSServiceErr_NoError) {
        std::cout << "[mDNS] Registered: " << name << " " << regtype
                  << " in " << domain << "\n";
    } else {
        std::cerr << "[mDNS] Registration error: " << error << "\n";
    }
}

bool MdnsService::register_airplay(const std::string& server_name, uint16_t port,
                                     const uint8_t hw_addr[6]) {
    std::string device_id = mac_to_string(hw_addr);
    std::string mac_id = mac_to_id(hw_addr);

    std::map<std::string, std::string> airplay_txt = {
        {"deviceid", device_id},
        {"features", "0x5A7FFFF7,0x1E"},
        {"flags", "0x44"},
        {"model", "AppleTV3,2"},
        {"pi", "2e388006-13ba-4041-9a67-25dd4a43d536"},
        {"pk", ""},
        {"srcvers", "220.68"},
        {"vv", "2"},
    };
    auto txt = build_txt_record(airplay_txt);

    DNSServiceErrorType err = DNSServiceRegister(
        &impl_->airplay_ref, 0, 0,
        server_name.c_str(), "_airplay._tcp",
        nullptr, nullptr, htons(port),
        static_cast<uint16_t>(txt.size()), txt.data(),
        register_callback, nullptr
    );
    if (err != kDNSServiceErr_NoError) {
        std::cerr << "[mDNS] Failed to register _airplay._tcp: " << err << "\n";
        return false;
    }

    std::string raop_name = mac_id + "@" + server_name;
    std::map<std::string, std::string> raop_txt = {
        {"ch", "2"}, {"cn", "0,1,2,3"}, {"da", "true"}, {"et", "0,3,5"},
        {"ft", "0x5A7FFFF7,0x1E"}, {"md", "0,1,2"}, {"pw", "false"},
        {"sr", "44100"}, {"ss", "16"}, {"sv", "false"}, {"tp", "UDP"},
        {"vn", "65537"}, {"vs", "220.68"}, {"vv", "2"},
    };
    auto raop_txtrec = build_txt_record(raop_txt);

    err = DNSServiceRegister(
        &impl_->raop_ref, 0, 0,
        raop_name.c_str(), "_raop._tcp",
        nullptr, nullptr, htons(port),
        static_cast<uint16_t>(raop_txtrec.size()), raop_txtrec.data(),
        register_callback, nullptr
    );
    if (err != kDNSServiceErr_NoError) {
        std::cerr << "[mDNS] Failed to register _raop._tcp: " << err << "\n";
        return false;
    }

    std::cout << "[mDNS] AirPlay advertised as '" << server_name
              << "' on port " << port << " (Bonjour)\n";
    return true;
}

void MdnsService::unregister() {
    if (impl_->airplay_ref) {
        DNSServiceRefDeallocate(impl_->airplay_ref);
        impl_->airplay_ref = nullptr;
    }
    if (impl_->raop_ref) {
        DNSServiceRefDeallocate(impl_->raop_ref);
        impl_->raop_ref = nullptr;
    }
}

// ============================================================
// Backend 2: Windows native DNS-SD (windns.h, Win10 1809+)
// ============================================================
#elif defined(MDNS_BACKEND_WINDNS)

static std::wstring to_wstring(const std::string& s) {
    if (s.empty()) return {};
    int len = MultiByteToWideChar(CP_UTF8, 0, s.data(), static_cast<int>(s.size()), nullptr, 0);
    std::wstring ws(len, 0);
    MultiByteToWideChar(CP_UTF8, 0, s.data(), static_cast<int>(s.size()), ws.data(), len);
    return ws;
}

static void WINAPI win_register_callback(
    DWORD status, PVOID context, PDNS_SERVICE_INSTANCE instance) {
    auto label = static_cast<const char*>(context);
    if (status == ERROR_SUCCESS) {
        std::cout << "[mDNS] Registered " << (label ? label : "service") << "\n";
    } else {
        std::cerr << "[mDNS] Registration callback error for "
                  << (label ? label : "service") << ": " << status << "\n";
    }
}

static PDNS_SERVICE_INSTANCE create_service_instance(
    const std::wstring& service_name,
    const std::wstring& hostname,
    uint16_t port,
    const std::vector<std::pair<std::wstring, std::wstring>>& properties) {

    std::vector<PCWSTR> keys;
    std::vector<PCWSTR> values;
    for (const auto& [k, v] : properties) {
        keys.push_back(k.c_str());
        values.push_back(v.c_str());
    }

    return DnsServiceConstructInstance(
        service_name.c_str(),
        hostname.c_str(),
        nullptr, nullptr,       // IP4, IP6 — let OS auto-detect
        port,                   // host byte order
        0, 0,                   // priority, weight
        static_cast<DWORD>(properties.size()),
        properties.empty() ? nullptr : keys.data(),
        properties.empty() ? nullptr : values.data()
    );
}

bool MdnsService::register_airplay(const std::string& server_name, uint16_t port,
                                     const uint8_t hw_addr[6]) {
    std::wstring wname = to_wstring(server_name);
    std::wstring device_id = to_wstring(mac_to_string(hw_addr));
    std::wstring mac_id = to_wstring(mac_to_id(hw_addr));

    // Get local hostname for SRV record
    wchar_t hostname_buf[256] = {};
    DWORD hostname_size = 256;
    GetComputerNameExW(ComputerNameDnsHostname, hostname_buf, &hostname_size);
    std::wstring hostname = std::wstring(hostname_buf) + L".local";

    // --- Register _airplay._tcp.local ---
    std::wstring airplay_svc = wname + L"._airplay._tcp.local";
    std::vector<std::pair<std::wstring, std::wstring>> airplay_props = {
        {L"deviceid", device_id},
        {L"features", L"0x5A7FFFF7,0x1E"},
        {L"flags",    L"0x44"},
        {L"model",    L"AppleTV3,2"},
        {L"pi",       L"2e388006-13ba-4041-9a67-25dd4a43d536"},
        {L"pk",       L""},
        {L"srcvers",  L"220.68"},
        {L"vv",       L"2"},
    };

    impl_->airplay_instance = create_service_instance(airplay_svc, hostname, port, airplay_props);
    if (!impl_->airplay_instance) {
        std::cerr << "[mDNS] Failed to construct _airplay._tcp instance\n";
        return false;
    }

    DNS_SERVICE_REGISTER_REQUEST req{};
    req.Version = DNS_QUERY_REQUEST_VERSION1;
    req.InterfaceIndex = 0;
    req.pServiceInstance = impl_->airplay_instance;
    req.pRegisterCompletionCallback = win_register_callback;
    req.pQueryContext = const_cast<char*>("_airplay._tcp");

    DWORD status = DnsServiceRegister(&req, &impl_->airplay_cancel);
    if (status != DNS_REQUEST_PENDING && status != ERROR_SUCCESS) {
        std::cerr << "[mDNS] DnsServiceRegister failed for _airplay._tcp: " << status << "\n";
        DnsServiceFreeInstance(impl_->airplay_instance);
        impl_->airplay_instance = nullptr;
        return false;
    }
    impl_->airplay_registered = true;

    // --- Register _raop._tcp.local ---
    std::wstring raop_svc = mac_id + L"@" + wname + L"._raop._tcp.local";
    std::vector<std::pair<std::wstring, std::wstring>> raop_props = {
        {L"ch", L"2"}, {L"cn", L"0,1,2,3"}, {L"da", L"true"}, {L"et", L"0,3,5"},
        {L"ft", L"0x5A7FFFF7,0x1E"}, {L"md", L"0,1,2"}, {L"pw", L"false"},
        {L"sr", L"44100"}, {L"ss", L"16"}, {L"sv", L"false"}, {L"tp", L"UDP"},
        {L"vn", L"65537"}, {L"vs", L"220.68"}, {L"vv", L"2"},
    };

    impl_->raop_instance = create_service_instance(raop_svc, hostname, port, raop_props);
    if (!impl_->raop_instance) {
        std::cerr << "[mDNS] Failed to construct _raop._tcp instance\n";
        return false;
    }

    DNS_SERVICE_REGISTER_REQUEST raop_req{};
    raop_req.Version = DNS_QUERY_REQUEST_VERSION1;
    raop_req.InterfaceIndex = 0;
    raop_req.pServiceInstance = impl_->raop_instance;
    raop_req.pRegisterCompletionCallback = win_register_callback;
    raop_req.pQueryContext = const_cast<char*>("_raop._tcp");

    status = DnsServiceRegister(&raop_req, &impl_->raop_cancel);
    if (status != DNS_REQUEST_PENDING && status != ERROR_SUCCESS) {
        std::cerr << "[mDNS] DnsServiceRegister failed for _raop._tcp: " << status << "\n";
        DnsServiceFreeInstance(impl_->raop_instance);
        impl_->raop_instance = nullptr;
        return false;
    }
    impl_->raop_registered = true;

    std::cout << "[mDNS] AirPlay advertised as '" << server_name
              << "' on port " << port << " (Windows DNS-SD)\n";
    return true;
}

void MdnsService::unregister() {
    if (impl_->airplay_registered) {
        DNS_SERVICE_REGISTER_REQUEST req{};
        req.Version = DNS_QUERY_REQUEST_VERSION1;
        req.pServiceInstance = impl_->airplay_instance;
        req.pRegisterCompletionCallback = win_register_callback;
        DnsServiceDeRegister(&req, nullptr);
        impl_->airplay_registered = false;
    }
    if (impl_->airplay_instance) {
        DnsServiceFreeInstance(impl_->airplay_instance);
        impl_->airplay_instance = nullptr;
    }
    if (impl_->raop_registered) {
        DNS_SERVICE_REGISTER_REQUEST req{};
        req.Version = DNS_QUERY_REQUEST_VERSION1;
        req.pServiceInstance = impl_->raop_instance;
        req.pRegisterCompletionCallback = win_register_callback;
        DnsServiceDeRegister(&req, nullptr);
        impl_->raop_registered = false;
    }
    if (impl_->raop_instance) {
        DnsServiceFreeInstance(impl_->raop_instance);
        impl_->raop_instance = nullptr;
    }
}

// ============================================================
// No DNS-SD backend available
// ============================================================
#else

bool MdnsService::register_airplay(const std::string&, uint16_t, const uint8_t[6]) {
    std::cerr << "[mDNS] No DNS-SD support available — AirPlay discovery disabled\n";
    return false;
}

void MdnsService::unregister() {}

#endif

} // namespace openmirror::airplay
